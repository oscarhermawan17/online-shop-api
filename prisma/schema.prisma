generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.svg"
  disabled = "true"
  theme    = "default"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(uuid())
  status    String
  createdAt DateTime @default(now())

  @@map("health_checks")
}

model Store {
  id                                     String                    @id @default(uuid())
  name                                   String
  description                            String?
  logoUrl                                String?
  bannerUrl                              String?
  footerText                             String?
  whatsappNumber                         String?
  email                                  String?
  address                                String?
  bankAccountName                        String?
  bankAccountNumber                      String?
  bankName                               String?
  qrisImageUrl                           String?
  createdAt                              DateTime                  @default(now())
  updatedAt                              DateTime                  @updatedAt
  deliveryRetailFreeShippingMinimumOrder Int?
  deliveryRetailMinimumOrder             Int?
  deliveryStoreFreeShippingMinimumOrder  Int?
  deliveryStoreMinimumOrder              Int?
  admins                                 Admin[]
  carouselSlides                         CarouselSlide[]
  categories                             Category[]
  creditPayments                         CreditPayment[]
  customerAddresses                      CustomerAddress[]
  customerCredits                        CustomerCredit[]
  customers                              Customer[]
  orderItems                             OrderItem[]
  shippingAssignments                    OrderShippingAssignment[]
  orders                                 Order[]
  orderComplaints                        OrderComplaint[]
  paymentProofs                          PaymentProof[]
  productDiscounts                       ProductDiscount[]
  productDiscountRules                   ProductDiscountRule[]
  productImages                          ProductImage[]
  productOptionValues                    ProductOptionValue[]
  productOptions                         ProductOption[]
  products                               Product[]
  shippingDrivers                        ShippingDriver[]
  shippingShifts                         ShippingShift[]
  shippingZones                          ShippingZone[]
  stockMovements                         StockMovement[]
  units                                  Unit[]
  variantDiscountRules                   VariantDiscountRule[]
  variants                               Variant[]

  @@map("stores")
}

model CarouselSlide {
  id              String   @id @default(uuid())
  storeId         String
  title           String
  subtitle        String?
  badge           String?
  imageUrl        String?
  backgroundColor String?
  showText        Boolean  @default(true)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([storeId, isActive, sortOrder])
  @@map("carousel_slides")
}

model Product {
  id             String           @id @default(uuid())
  storeId        String
  name           String
  description    String?
  basePrice      Int
  wholesalePrice Int?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  unitId         String?
  discount       ProductDiscount?
  images         ProductImage[]
  options        ProductOption[]
  productDiscountRules ProductDiscountRule[]
  store          Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  unit           Unit?            @relation(fields: [unitId], references: [id])
  stockMovements StockMovement[]
  variants       Variant[]
  categories     Category[]       @relation("CategoryToProduct")

  @@index([storeId])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  storeId   String
  productId String
  imageUrl  String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("product_images")
}

model ProductOption {
  id        String               @id @default(uuid())
  storeId   String
  productId String
  name      String
  values    ProductOptionValue[]
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("product_options")
}

model ProductOptionValue {
  id             String               @id @default(uuid())
  storeId        String
  optionId       String
  value          String
  option         ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  store          Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variantOptions VariantOptionValue[]

  @@index([storeId])
  @@map("product_option_values")
}

model Variant {
  id                     String                @id @default(uuid())
  storeId                String
  productId              String
  name                   String?
  isDefault              Boolean               @default(false)
  priceOverride          Int?
  wholesalePriceOverride Int?
  stock                  Int                   @default(0)
  createdAt              DateTime              @default(now())
  imageUrl               String?
  stockMovements         StockMovement[]
  discountRules          VariantDiscountRule[]
  optionValues           VariantOptionValue[]
  product                Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  store                  Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("variants")
}

model VariantOptionValue {
  id            String             @id @default(uuid())
  variantId     String
  optionValueId String
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)
  variant       Variant            @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@map("variant_option_values")
}

model VariantDiscountRule {
  id           String              @id @default(uuid())
  storeId      String
  variantId    String
  name         String?
  triggerType  DiscountTriggerType
  minThreshold Int
  maxThreshold Int?
  valueType    DiscountValueType
  value        Int
  applyMode    DiscountApplyMode
  customerType CustomerType?
  isActive     Boolean             @default(true)
  priority     Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant      Variant             @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([variantId])
  @@index([variantId, isActive])
  @@index([variantId, customerType, isActive])
  @@map("variant_discount_rules")
}

model ProductDiscountRule {
  id               String              @id @default(uuid())
  storeId          String
  productId        String
  name             String?
  triggerType      DiscountTriggerType
  minThreshold     Int
  maxThreshold     Int?
  valueType        DiscountValueType
  value            Int
  applyMode        DiscountApplyMode
  customerType     CustomerType?
  isActive         Boolean             @default(true)
  priority         Int                 @default(0)
  targetVariantIds String[]            @default([])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  product          Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  store            Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([productId, isActive])
  @@index([productId, customerType, isActive])
  @@map("product_discount_rules")
}

model Customer {
  id        String            @id @default(uuid())
  storeId   String
  name      String?
  phone     String
  email     String?
  password  String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @default(now()) @updatedAt
  type      CustomerType      @default(base)
  avatarUrl String?
  addresses CustomerAddress[]
  credit          CustomerCredit?
  orderComplaints OrderComplaint[]
  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders          Order[]

  @@unique([storeId, phone])
  @@index([storeId])
  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(uuid())
  storeId    String
  customerId String
  label      String
  recipient  String
  phone      String
  address    String
  district   String?
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@map("customer_addresses")
}

model Order {
  id                 String                   @id @default(uuid())
  storeId            String
  customerId         String
  publicOrderId      String                   @unique
  status             OrderStatus              @default(pending_payment)
  customerName       String?
  customerPhone      String?
  customerAddress    String?
  deliveryMethod     String?
  notes              String?
  shippingCost       Int                      @default(0)
  totalAmount        Int
  expiresAt          DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  creditSettledAt    DateTime?
  paymentMethod         PaymentMethod            @default(bank_transfer)
  termOfPaymentSnapshot Int                      @default(0)
  adminCompletedAt      DateTime?
  customerCompletedAt   DateTime?
  creditPayments     CreditPayment[]
  items              OrderItem[]
  shippingAssignment OrderShippingAssignment?
  customer           Customer                 @relation(fields: [customerId], references: [id])
  store              Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  paymentProof       PaymentProof?
  complaints         OrderComplaint[]

  @@index([storeId])
  @@index([customerId])
  @@map("orders")
}

model CustomerCredit {
  id              String   @id @default(uuid())
  storeId         String
  customerId      String   @unique
  creditLimit     Int      @default(0)
  termOfPayment   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("customer_credits")
}

model CreditPayment {
  id         String   @id @default(uuid())
  storeId    String
  orderId    String
  amount     Int
  receivedAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@map("credit_payments")
}

model OrderItem {
  id                 String  @id @default(uuid())
  storeId            String
  orderId            String
  productName        String
  variantDescription String?
  price              Int
  quantity           Int
  variantId          String?
  discountAmount     Int     @default(0)
  discountRuleName   String?
  originalPrice      Int?
  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store              Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("order_items")
}

model PaymentProof {
  id         String   @id @default(uuid())
  storeId    String
  orderId    String   @unique
  imageUrl   String
  uploadedAt DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("payment_proofs")
}

model ShippingZone {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  cost      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, name])
  @@index([storeId])
  @@map("shipping_zones")
}

model ShippingDriver {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, name])
  @@index([storeId])
  @@index([storeId, isActive])
  @@map("shipping_drivers")
}

model ShippingShift {
  id          String                    @id @default(uuid())
  storeId     String
  name        String
  startTime   String
  endTime     String
  isActive    Boolean                   @default(true)
  sortOrder   Int?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  assignments OrderShippingAssignment[]
  store       Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, name, startTime, endTime])
  @@index([storeId])
  @@index([storeId, isActive])
  @@map("shipping_shifts")
}

model OrderShippingAssignment {
  id                String        @id @default(uuid())
  storeId           String
  orderId           String        @unique
  shiftId           String
  deliveryDate      DateTime
  driverName        String
  assignedAt        DateTime      @default(now())
  assignedByAdminId String?
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shift             ShippingShift @relation(fields: [shiftId], references: [id])
  store             Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([shiftId])
  @@map("order_shipping_assignments")
}

model OrderComplaint {
  id                String               @id @default(uuid())
  storeId           String
  orderId           String
  customerId        String
  comment           String
  evidenceImageUrls Json
  status            OrderComplaintStatus @default(open)
  adminNote         String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  resolvedAt        DateTime?
  acceptedByAdminId String?
  rejectedByAdminId String?
  resolvedByAdminId String?
  customer          Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order             Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store             Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([customerId])
  @@index([storeId, status, createdAt])
  @@map("order_complaints")
}

model Admin {
  id                    String          @id @default(uuid())
  storeId               String
  name                  String
  phone                 String          @unique
  email                 String?
  password              String
  role                  AdminRole       @default(owner)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  store                 Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdStockMovements StockMovement[] @relation("AdminStockMovements")

  @@index([storeId])
  @@map("admins")
}

model StockMovement {
  id               String                @id @default(uuid())
  storeId          String
  productId        String
  variantId        String
  stockStatus      StockMovementStatus
  quantity         Int
  category         StockMovementCategory
  balanceAfter     Int
  referenceType    String?
  referenceId      String?
  notes            String?
  createdByAdminId String?
  createdAt        DateTime              @default(now())
  createdByAdmin   Admin?                @relation("AdminStockMovements", fields: [createdByAdminId], references: [id])
  product          Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  store            Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant          Variant               @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([variantId])
  @@index([storeId, createdAt])
  @@index([storeId, productId, createdAt])
  @@index([storeId, variantId, createdAt])
  @@map("stock_movements")
}

model ProductDiscount {
  id                   String    @id @default(uuid())
  storeId              String
  productId            String    @unique
  normalDiscount       Int?
  normalDiscountActive Boolean   @default(false)
  retailDiscount       Int?
  retailDiscountActive Boolean   @default(false)
  startDate            DateTime?
  endDate              DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  product              Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  store                Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("product_discounts")
}

model Category {
  id        String    @id @default(uuid())
  storeId   String
  name      String
  icon      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  Product[] @relation("CategoryToProduct")

  @@index([storeId])
  @@map("categories")
}

model Unit {
  id        String    @id @default(uuid())
  storeId   String
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("units")
}

enum OrderStatus {
  pending_payment
  waiting_confirmation
  paid
  shipped
  done
  cancelled
  expired_unpaid
}

enum OrderComplaintStatus {
  open
  accepted
  rejected
  resolved
}

enum PaymentMethod {
  bank_transfer
  credit
}

enum AdminRole {
  owner
  manager
  staff
}

enum CustomerType {
  base
  wholesale
}

enum DiscountTriggerType {
  quantity
  line_subtotal
}

enum DiscountValueType {
  percentage
  fixed_amount
}

enum DiscountApplyMode {
  per_item
  line_total
}

enum StockMovementStatus {
  in
  out
}

enum StockMovementCategory {
  initial_stock
  add_stock
  sale
  restore
}
